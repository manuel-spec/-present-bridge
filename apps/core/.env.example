# Core server
HOST=0.0.0.0
HTTP_PORT=3000

# LAN IP announced to WebRTC clients (required for real devices on the network)
ANNOUNCED_IP=192.168.1.100

# mediasoup RTC port range
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
MEDIASOUP_WORKER_COUNT=1

# mDNS LAN discovery
MDNS_ENABLED=true
MDNS_SERVICE_NAME=packet-bridge

# Set to true to allow missing ANNOUNCED_IP (localhost dev only)
DEV_MODE=false
